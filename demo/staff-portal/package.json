{
  "name": "staff-portal",
  "version": "0.0.1",
  "private": true,
  "sideEffects": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "bun ./observability/dev-start.js",
    "start": "bun ./observability/start.js",
    "lint": "bunx eslint \"{app,lib}/**/*.{ts,tsx}\" --fix",
    "format": "bunx prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" \"!**/locales/**\"",
    "format:check": "bunx prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\" \"!**/locales/**\"",
    "typecheck": "bunx react-router typegen && tsc",
    "i18n:extract": "lingui extract --clean",
    "i18n:compile": "lingui compile --typescript",
    "test:unit": "vitest",
    "test:unit:prod": "vitest run",
    "test:unit:debug": "vitest --ui",
    "test:e2e": "start-server-and-test 'bun run dev' http://localhost:3000 'bunx cypress run'",
    "test:e2e:prod": "start-server-and-test 'bun run start' http://localhost:3000 'bunx cypress run --quiet'",
    "test:e2e:debug": "start-server-and-test 'bun run start' http://localhost:3000 'bunx cypress open'",
    "openapi:list": "bun scripts/openapi-list.ts",
    "openapi:generate": "bun scripts/openapi.ts"
  },
